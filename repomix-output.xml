                    <div className={`w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 border-2 transition-all ${
                      active ? "bg-emerald-500 border-emerald-500" : "border-zinc-600"
                    }`}>
                      {active && <Check className="w-3.5 h-3.5 text-zinc-950" strokeWidth={3} />}
                    </div>
                  </button>
                )
              })}
