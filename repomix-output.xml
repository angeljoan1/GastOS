<file path="types/index.ts">
// types/index.ts
// ─── Fuente Única de Verdad para todos los tipos de GastOS ───

export type TipoMovimiento = 'gasto' | 'ingreso' | 'transferencia'
export type TipoCategoria  = 'gasto' | 'ingreso' | 'ambos'
export type TipoCuenta     = 'banco' | 'efectivo' | 'tarjeta' | 'inversion' | 'otro'

// ─── Categoría ───────────────────────────────────────────────
// 'icono' es ahora un string con el nombre del componente de
// lucide-react (ej: "UtensilsCrossed", "Wallet").
// El componente se resuelve en tiempo de ejecución mediante
// un mapa de iconos centralizado (se implementará en Fase 2).
export interface Categoria {
  id:    string
  label: string
  icono: string       // Antes era "Icon: any" — ahora serializable
  tipo:  TipoCategoria
}

// ─── Cuenta / Cartera ────────────────────────────────────────
export interface Cuenta {
  id:            string
  user_id:       string
  nombre:        string
  tipo:          TipoCuenta
  icono:         string       // Nombre del icono de lucide-react
  color:         string       // Color HEX para la UI
  saldo_inicial: number
  created_at:    string
}

// ─── Movimiento ──────────────────────────────────────────────
export interface Movimiento {
  id:                 string
  created_at:         string
  cantidad:           number
  categoria:          string
  nota?:              string | null
  is_recurring?:      boolean
  tipo?:              TipoMovimiento
  cuenta_id?:         string | null  // Obligatorio en movimientos nuevos
  cuenta_destino_id?: string | null  // Solo para tipo = 'transferencia'
}

// ─── Saldo calculado (se usa en la UI, no en la DB) ──────────
// El saldo_actual se computa siempre desde los movimientos,
// nunca se persiste. Esto garantiza consistencia total.
export interface SaldoCuenta {
  cuenta:       Cuenta
  saldo_actual: number
}
</file>

