/* app/globals.css */
/* ─── Fixes en este archivo ──────────────────────────────────────────────────
   BUG #24: globals.css declaraba font-family: Arial en body, compitiendo con
            la variable CSS de Geist Sans que layout.tsx aplica en <html>.
            Aunque Geist ganaba en la práctica por especificidad, la declaración
            de Arial era confusa y podía causar flash of unstyled text en SSR.
            FIX: eliminamos la declaración de font-family en body y dejamos que
            la herencia desde <html> (donde layout.tsx aplica --font-geist-sans)
            actúe de forma limpia.
   ──────────────────────────────────────────────────────────────────────────── */

   @import "tailwindcss";

   :root {
     --background: #ffffff;
     --foreground: #171717;
   }
   
   @theme inline {
     --color-background: var(--background);
     --color-foreground: var(--foreground);
     --font-sans: var(--font-geist-sans);
     --font-mono: var(--font-geist-mono);
   }
   
   @media (prefers-color-scheme: dark) {
     :root {
       --background: #0a0a0a;
       --foreground: #ededed;
     }
   }
   
   html, body {
    background: #09090b;
    color:      var(--foreground);
  }

  @media (display-mode: standalone) {
    html, body {
      overscroll-behavior: none;
    }
  }

  @layer utilities {
   .pt-safe-top {
     padding-top: env(safe-area-inset-top);
   }
   .pb-safe-bottom {
     padding-bottom: env(safe-area-inset-bottom);
   }
 }
  
